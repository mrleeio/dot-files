{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "Authored-By: Michael Lee <michael@mrlee.io>",
    "pr": ""
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "brew *",
      "chezmoi *",
      "docker *",
      "docker-compose *",
      "gh *",
      "git *",
      "mise *",
      "scp *",
      "ssh *"
    ],
    "filesystem": {
      "denyRead": [
        "~/.ssh/id_*",
        "~/.aws/credentials",
        "~/.gnupg/**",
        "~/.config/gh/hosts.yml",
        "~/.config/atuin/key",
        "~/.config/chezmoi/key.txt",
        "~/.docker/config.json",
        "~/.netrc",
        "~/.npmrc",
        "~/.gem/credentials"
      ],
      "denyWrite": [
        "/etc",
        "/usr/local",
        "/opt/homebrew",
        "~/.ssh",
        "~/.gnupg",
        "~/.config/chezmoi"
      ]
    },
    "network": {
      "allowAllUnixSockets": true,
      "allowLocalBinding": true,
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "rubygems.org",
        "*.rubygems.org",
        "api.anthropic.com",
        "api.githubcopilot.com",
        "raw.githubusercontent.com",
        "pypi.org",
        "files.pythonhosted.org",
        "proxy.golang.org",
        "sum.golang.org",
        "formulae.brew.sh",
        "ghcr.io",
        "*.ghcr.io",
        "registry-1.docker.io",
        "auth.docker.io",
        "production.cloudflare.docker.com",
        "mise.jdx.dev",
        "luarocks.org",
        "atuin.sh"
      ]
    }
  },
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Read(~/GitHub/**)",
      "WebFetch",
      "Bash(gh auth status)",
      "Bash(gh auth status *)",
      "Bash(gh status)",
      "Bash(gh status *)",
      "Bash(gh repo list)",
      "Bash(gh repo list *)",
      "Bash(gh repo view)",
      "Bash(gh repo view *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr status)",
      "Bash(gh pr status *)",
      "Bash(gh issue list)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status)",
      "Bash(gh issue status *)",
      "Bash(gh run list)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh release list)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh workflow list)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow view *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git remote)",
      "Bash(git remote *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git pull)",
      "Bash(git pull *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git tag)",
      "Bash(git tag *)",
      "Bash(git merge *)",
      "Bash(rails generate *)",
      "Bash(rails destroy *)",
      "Bash(rails routes)",
      "Bash(rails routes *)",
      "Bash(rails test)",
      "Bash(rails test *)",
      "Bash(rails server)",
      "Bash(rails server *)",
      "Bash(rails console)",
      "Bash(rails console *)",
      "Bash(rails db:migrate)",
      "Bash(rails db:migrate *)",
      "Bash(rails db:rollback)",
      "Bash(rails db:rollback *)",
      "Bash(rails db:seed)",
      "Bash(rails db:seed *)",
      "Bash(rails db:version)",
      "Bash(rails db:schema:dump)",
      "Bash(rails db:schema:dump *)",
      "Bash(rails assets:precompile)",
      "Bash(rails assets:precompile *)",
      "Bash(bundle install)",
      "Bash(bundle install *)",
      "Bash(bundle exec *)",
      "Bash(bundle add *)",
      "Bash(bundle list)",
      "Bash(bundle list *)",
      "Bash(bundle show *)",
      "Bash(bundle info *)",
      "Bash(mise install *)",
      "Bash(mise use *)",
      "Bash(mise list)",
      "Bash(mise list *)",
      "Bash(brew list)",
      "Bash(brew list *)",
      "Bash(brew info *)",
      "Bash(brew search *)",
      "Bash(chezmoi diff)",
      "Bash(chezmoi diff *)",
      "Bash(chezmoi status)",
      "Bash(chezmoi status *)"
    ],
    "deny": [
      "Bash(> .env*)",
      "Bash(cat .env*)",
      "Bash(cat */.env*)",
      "Bash(cat secrets/*)",
      "Bash(curl *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(wget *)",
      "Read(./secrets/**)",
      "Read(.env.*)",
      "Read(.env)",
      "Read(~/.aws/credentials)",
      "Read(~/.gnupg/**)",
      "Read(~/.ssh/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.docker/config.json)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.gem/credentials)",
      "Read(~/.config/atuin/key)",
      "Read(~/.config/chezmoi/key.txt)"
    ]
  }
}
